@page "/mihistoria"

<PageTitle>Mi historia</PageTitle>

<div class="p-4 mb-4 bg-light rounded-3">
    <div class="container-fluid py-2">
        <h1 class="fw-bold">Mi historia</h1>
        <p class="fs-5">A continuación les escribiré información relevante de mi vida.</p>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <img src="images/laptop.jpg" class="card-img-top" alt="Laptop Dell">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Formación</h5>
                <p class="card-text">Cuento algo sobre mi formación profesional.</p>
                <div class="mt-auto">
                    <button class="btn btn-primary">Conocer mas</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <img src="images/monitor.jpg" class="card-img-top" alt="Monitor">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Hobbies</h5>
                <p class="card-text">Cuento algo sobre mis hobbies.</p>
                <div class="mt-auto">
                    <button class="btn btn-primary">Conocer mas</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <img src="images/pc.jpg" class="card-img-top" alt="Computadora de escritorio">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Mi carrera</h5>
                <p class="card-text">Cuento algo sobre lo que espero de mi carrera.</p>
                <div class="mt-auto">
                    <button class="btn btn-primary">Conocer mas</button>
                </div>
            </div>
        </div>
    </div>
</div>