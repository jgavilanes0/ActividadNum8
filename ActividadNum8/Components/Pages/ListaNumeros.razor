@page "/listanumeros"
@rendermode InteractiveServer

<PageTitle>Lista de números</PageTitle>

<div class="container mt-4" style="max-width: 800px; margin-left: 0;">
    <h3 class="mb-4">Listas de numeros</h3>

    <div class="row mb-3 align-items-center">
        <div class="col-md-2">
            <label class="col-form-label">Número 1</label>
        </div>
        <div class="col-md-10">
            <input type="number" class="form-control" @bind="numero1" />
        </div>
    </div>

    <div class="row mb-4 align-items-center">
        <div class="col-md-2">
            <label class="col-form-label">Número 2</label>
        </div>
        <div class="col-md-10">
            <input type="number" class="form-control" @bind="numero2" />
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <button class="btn btn-primary" @onclick="CalcularListas">Calcular</button>
        </div>
    </div>

    @if (pares.Count > 0 || impares.Count > 0)
    {
        <div class="row mt-4">
            <div class="col-md-6">
                <h4 class="fw-normal">Pares</h4>
                <table class="table table-striped table-borderless">
                    <tbody>
                        @foreach (var par in pares)
                        {
                            <tr>
                                <td class="py-3">@par</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="col-md-6">
                <h4 class="fw-normal">Impares</h4>
                <table class="table table-striped table-borderless">
                    <tbody>
                        @foreach (var impar in impares)
                        {
                            <tr>
                                <td class="py-3">@impar</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private int numero1 = 0;
    private int numero2 = 0;
    private List<int> pares = new List<int>();
    private List<int> impares = new List<int>();

    private void CalcularListas()
    {
        pares.Clear();
        impares.Clear();
        int menor = numero1;
        int mayor = numero2;
        if (numero1 > numero2)
        {
            menor = numero2;
            mayor = numero1;
        }
        for (int i = menor; i <= mayor; i++)
        {
            if (i % 2 == 0)
            {
                pares.Add(i);
            }
            else
            {
                impares.Add(i);
            }
        }
    }
}