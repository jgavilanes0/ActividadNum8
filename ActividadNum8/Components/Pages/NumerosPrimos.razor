@page "/numerosprimos"
@rendermode InteractiveServer

<PageTitle>Números primos</PageTitle>

<div class="container mt-4" style="max-width: 800px; margin-left: 0;">
    <h3 class="mb-4">Numeros primos</h3>

    <div class="row mb-3 align-items-center">
        <div class="col-md-3">
            <label class="col-form-label">Número entero</label>
        </div>
        <div class="col-md-9">
            <input type="number" class="form-control" @bind="numeroLimite" min="1" />
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <button class="btn btn-primary" @onclick="GenerarListaPrimos">Generar primos</button>
        </div>
    </div>

    @if (primos != null && primos.Any())
    {
        <h3 class="mt-4 mb-3">Números primos</h3>
        
        <table class="table table-striped table-borderless">
            <tbody>
                @foreach (var primo in primos)
                {
                    <tr>
                        <td class="py-3">@primo</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private int numeroLimite = 0;
    private List<int> primos = new List<int>();
    private void GenerarListaPrimos()
    {
        primos.Clear();

        if (numeroLimite >= 2)
        {
            for (int i = 2; i <= numeroLimite; i++)
            {
                if (EsPrimo(i))
                {
                    primos.Add(i);
                }
            }
        }
    }
    private bool EsPrimo(int numero)
    {
        if (numero < 2) return false;
        for (int i = 2; i <= Math.Sqrt(numero); i++)
        {
            if (numero % i == 0) return false;
        }
        
        return true;
    }
}